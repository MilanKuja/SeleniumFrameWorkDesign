<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<suite parallel ="tests" name="Suite">
    <listeners>
        <listener class-name="rahulshettyAcedamy.TestComponents.Listeners"/>
    </listeners>
    
    <test thread-count="5" name="Submit Order Test">
        <classes>
            <class name="rahulshettyacademy.tests.StandAloneTest"/>
        </classes>
    </test>

    <test thread-count="5" name="Error Validations Test">
        <classes>
            <class name="rahulshettyacademy.tests.ErrorValidatonsTest"/>
        </classes>
    </test>
</suite>